<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ae="using:AvaloniaEdit"
             xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
             xmlns:ctxt="clr-namespace:ColorTextBlock.Avalonia;assembly=ColorTextBlock.Avalonia"
             xmlns:vm="using:NoteMode.ViewModels"
             x:Class="NoteMode.Views.EditorView"
             x:DataType="vm:TabViewModel">

    <Grid>
        <ae:TextEditor x:Name="Editor"
                       SyntaxHighlighting="{Binding SyntaxHighlighting}"
                       HorizontalScrollBarVisibility="Auto"
                       VerticalScrollBarVisibility="Auto"
                       WordWrap="False"
                       Margin="8,0,0,0"
                       IsVisible="{Binding !IsPreview}" />

        <!-- Rendered Markdown preview -->
        <Border Background="{DynamicResource TabItemSelected}"
                Padding="24,16,24,24"
                IsVisible="{Binding IsPreview}">
            <md:MarkdownScrollViewer x:Name="Preview"
                                     Markdown="{Binding Content}"
                                     MarkdownStyleName="Standard">
                <!-- Override the Standard (light) style colors to match the app theme.
                     Inserted after the Standard style, so equal-specificity setters win. -->
                <md:MarkdownScrollViewer.Styles>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource MdText}"/>
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.Heading1">
                        <Setter Property="Foreground" Value="{DynamicResource MdHeading1}"/>
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.Heading2">
                        <Setter Property="Foreground" Value="{DynamicResource MdHeading2}"/>
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.Heading3">
                        <Setter Property="Foreground" Value="{DynamicResource MdHeading3}"/>
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.Heading4">
                        <Setter Property="Foreground" Value="{DynamicResource MdHeading4}"/>
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.Heading5">
                        <Setter Property="Foreground" Value="{DynamicResource MdHeading5}"/>
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CTextBlock.Heading6">
                        <Setter Property="Foreground" Value="{DynamicResource MdHeading6}"/>
                    </Style>

                    <!-- Inline code and code blocks -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CCode">
                        <Setter Property="Foreground" Value="{DynamicResource MdCodeForeground}"/>
                        <Setter Property="Background" Value="{DynamicResource MdCodeBackground}"/>
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.CodeBlock">
                        <Setter Property="Background" Value="{DynamicResource MdCodeBackground}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource MdCodeBackground}"/>
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer TextBlock.CodeBlock">
                        <Setter Property="Foreground" Value="{DynamicResource MdCodeForeground}"/>
                    </Style>

                    <!-- Links -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer ctxt|CHyperlink">
                        <Setter Property="Foreground" Value="{DynamicResource MdLink}"/>
                        <Setter Property="HoverForeground" Value="{DynamicResource MdHeading1}"/>
                    </Style>

                    <!-- Blockquote -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.Blockquote">
                        <Setter Property="BorderBrush" Value="{DynamicResource MdBlockquoteBorder}"/>
                    </Style>

                    <!-- Tables -->
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.Table">
                        <Setter Property="BorderBrush" Value="{DynamicResource MdTableBorder}"/>
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Grid.Table &gt; Border">
                        <Setter Property="BorderBrush" Value="{DynamicResource MdTableBorder}"/>
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.TableHeader">
                        <Setter Property="Background" Value="{DynamicResource MdTableHeaderBackground}"/>
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.OddTableRow">
                        <Setter Property="Background" Value="{DynamicResource MdTableRowOdd}"/>
                    </Style>
                    <Style Selector=".Markdown_Avalonia_MarkdownViewer Border.EvenTableRow">
                        <Setter Property="Background" Value="{DynamicResource MdTableRowEven}"/>
                    </Style>
                </md:MarkdownScrollViewer.Styles>
            </md:MarkdownScrollViewer>
        </Border>

        <!-- Preview / edit toggle (only for Markdown) -->
        <Button x:Name="PreviewToggle"
                Click="PreviewToggle_Click"
                IsVisible="{Binding CanPreview}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,18,0"
                Padding="6"
                Background="{DynamicResource NewTabButtonBackground}"
                ToolTip.Tip="Toggle Markdown preview (Ctrl+Shift+V)">
            <Panel>
                <!-- Eye icon: shown in edit mode (click to preview) -->
                <Path Data="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0z M15 12a3 3 0 1 0-6 0 3 3 0 0 0 6 0z"
                      Stroke="{DynamicResource MenuIconColor}" StrokeThickness="1.5"
                      StrokeLineCap="Round" StrokeJoin="Round" Stretch="Uniform"
                      Width="16" Height="16"
                      IsVisible="{Binding !IsPreview}" />
                <!-- Pencil icon: shown in preview mode (click to edit) -->
                <Path Data="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7 M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"
                      Stroke="{DynamicResource MenuIconColor}" StrokeThickness="1.5"
                      StrokeLineCap="Round" StrokeJoin="Round" Stretch="Uniform"
                      Width="16" Height="16"
                      IsVisible="{Binding IsPreview}" />
            </Panel>
        </Button>
    </Grid>
</UserControl>
